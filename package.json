{
  "name": "java-postfix-completion",
  "displayName": "Java Postfix Completion",
  "description": "Postfix completion for Java with type hierarchy awareness",
  "version": "0.1.0",
  "publisher": "java-postfix",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onLanguage:java"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/user/java-postfix-completion"
  },
  "contributes": {
    "configuration": {
      "title": "Java Postfix Completion",
      "properties": {
        "javaPostfixCompletion.templates": {
          "type": "array",
          "default": [],
          "description": "Custom postfix templates"
        }
      }
    }
  },
  "extensionDependencies": [
    "redhat.java"
  ],
  "license": "MIT",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "mocha --require ts-node/register 'test/**/*.test.ts' --ignore 'test/e2e/**'",
    "test:e2e": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/sinon": "^17.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.9.2",
    "chai": "^4.3.0",
    "mocha": "^10.2.0",
    "sinon": "^17.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  }
}
