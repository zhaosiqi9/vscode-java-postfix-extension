{
  "name": "java-postfix-completion",
  "displayName": "Java Postfix Completion",
  "description": "Postfix completion for Java with type hierarchy awareness",
  "version": "0.0.3-fix",
  "publisher": "java-postfix",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onLanguage:java"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/zhaosiqi9/vscode-java-postfix-extension"
  },
  "contributes": {
    "configuration": {
      "title": "Java Postfix Completion",
      "properties": {
        "javaPostfixCompletion.templates": {
          "type": "array",
          "default": [],
          "description": "Custom postfix templates"
        },
        "javaPostfixCompletion.completionMode": {
          "type": "string",
          "enum": ["inline", "manual", "manualWithType"],
          "default": "inline",
          "enumDescriptions": [
            "出现在系统补全列表中（点号触发），不做类型检查",
            "仅通过快捷键触发（Alt+S），不做类型检查",
            "仅通过快捷键触发（Alt+S），启用类型检查——过滤不匹配模板，$TYPE$ 替换为真实类型名"
          ],
          "description": "补全模式"
        }
      }
    },
    "commands": [
      {
        "command": "java-postfix.triggerSuggest",
        "title": "Java Postfix: Trigger Suggestion"
      }
    ],
    "keybindings": [
      {
        "command": "java-postfix.triggerSuggest",
        "key": "alt+s",
        "when": "editorLangId == java"
      }
    ]
  },
  "extensionDependencies": [
    "redhat.java"
  ],
  "license": "MIT",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "mocha --require ts-node/register 'test/**/*.test.ts' --ignore 'test/e2e/**'",
    "test:e2e": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/sinon": "^17.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "@vscode/vsce": "^3.9.2",
    "chai": "^4.3.0",
    "mocha": "^10.2.0",
    "sinon": "^17.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.0"
  }
}
